# ---- Copy this file to .env.local and fill in the values ----
# (scripts/setup-aws.sh can generate this file for you automatically)

# Admin login — you choose these. Used only on the server.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# Secret used to sign the admin session cookie.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# AWS region where the table + bucket live
AWS_REGION=us-east-1

# DynamoDB table name (created by scripts/setup-aws.sh)
DYNAMODB_TABLE=baby-registry

# S3 bucket for uploaded product photos (must be globally unique)
S3_BUCKET=baby-registry-images-CHANGEME

# AWS credentials for an IAM user scoped to the table + bucket.
# Locally: put them here. On Vercel: set them in Project Settings > Environment Variables.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Branding shown in the public header
NEXT_PUBLIC_REGISTRY_TITLE=Baby Registry
NEXT_PUBLIC_REGISTRY_SUBTITLE=We're having a baby!
